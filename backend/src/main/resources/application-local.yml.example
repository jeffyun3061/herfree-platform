# Example only — copy to application-local.yml (gitignored). Do NOT commit application-local.yml.
spring:
  config:
    activate:
      on-profile: local
    import:
      - optional:file:./local-secrets.yml
      - optional:file:./backend/local-secrets.yml

  datasource:
    url: jdbc:mysql://localhost:3306/herfree_db?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
    username: herfree_user
    password: herfree_pass

  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        format_sql: true

jwt:
  # 로컬 전용 시크릿 — 32자 이상 임의 문자열로 변경하세요. 운영 서버에는 절대 이 값을 쓰지 마세요.
  secret: local-dev-secret-change-this-to-random-32chars-minimum
  access-expiration-seconds: 3600

# 로컬 고정 관리자 (서버 재시작 시 role·비밀번호 동기화)
app:
  bootstrap:
    enabled: true
    email: admin@herfree.local
    password: HerfreeAdmin01
    nickname: HerfreeOps
    sync-existing: true
  # access-key / secret-key → local-secrets.yml (gitignore) 또는 S3_ACCESS_KEY 환경변수
  # 이 파일에 access-key를 빈 플레이스홀더로 두지 마세요 (local-secrets 덮어씀)
  s3:
    bucket: ${S3_BUCKET:${AWS_S3_BUCKET:herfree-dev-uploads}}
    region: ${S3_REGION:${AWS_REGION:ap-northeast-2}}
    public-base-url: ${S3_PUBLIC_BASE_URL:}

springdoc:
  api-docs:
    enabled: true
  swagger-ui:
    enabled: true
