# docker-compose.prod.yml 용 — .env.prod 로 복사 후 값을 채운다 (git 커밋 금지)
MYSQL_DATABASE=herfree_db
MYSQL_USER=herfree_user
MYSQL_PASSWORD=change_me_strong_password
MYSQL_ROOT_PASSWORD=change_me_root_password

# openssl rand -base64 32 로 생성
JWT_SECRET=change_me_jwt_secret_min_32_chars

JWT_ACCESS_EXPIRATION=3600

# Vercel production URL (preview 도메인도 쉼표로 추가 가능)
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

# 게시글 이미지 (S3 presigned upload)
S3_BUCKET=herfree-prod-uploads
S3_REGION=ap-northeast-2
# VPS에 IAM 역할을 붙일 수 있으면 키를 비워 두고 역할만 사용 (권장)
S3_ACCESS_KEY=
S3_SECRET_KEY=
# CloudFront 등 CDN URL (선택, 없으면 버킷 직접 URL)
S3_PUBLIC_BASE_URL=

# 운영 필수 — true 로 두지 말 것 (docker-compose도 false 고정)
ADMIN_BOOTSTRAP_ENABLED=false

# 호환 별칭 (선택): AWS_S3_BUCKET, AWS_REGION, AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY
