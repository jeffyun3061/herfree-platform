# Production profile template — use environment variables on EC2/RDS.
# Do NOT commit application-prod.yml or real secrets to git.
# Set SPRING_DATASOURCE_* and JWT_SECRET via EC2 env, Secrets Manager, or CI secrets.
spring:
  config:
    activate:
      on-profile: prod

  datasource:
    url: ${SPRING_DATASOURCE_URL}
    username: ${SPRING_DATASOURCE_USERNAME}
    password: ${SPRING_DATASOURCE_PASSWORD}

  jpa:
    hibernate:
      ddl-auto: validate
    show-sql: false

jwt:
  secret: ${JWT_SECRET}
  access-expiration-seconds: ${JWT_ACCESS_EXPIRATION:3600}

app:
  bootstrap:
    enabled: false
  s3:
    bucket: ${S3_BUCKET:${AWS_S3_BUCKET:}}
    region: ${S3_REGION:${AWS_REGION:ap-northeast-2}}
    # 운영: IAM 역할(인스턴스 프로파일) 권장 — 키 비우면 SDK가 역할에서 자격 증명을 읽는다.
    access-key: ${S3_ACCESS_KEY:${AWS_ACCESS_KEY_ID:}}
    secret-key: ${S3_SECRET_KEY:${AWS_SECRET_ACCESS_KEY:}}
    public-base-url: ${S3_PUBLIC_BASE_URL:}
