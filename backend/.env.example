# Local backend secrets — copy to OS env or IDE run config. Never commit real values.
# PowerShell example:
#   $env:S3_ACCESS_KEY="..."
#   $env:S3_SECRET_KEY="..."
#   ./gradlew bootRun

S3_BUCKET=herfree-dev-uploads
S3_REGION=ap-northeast-2
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_BASE_URL=

# Aliases (optional): AWS_S3_BUCKET, AWS_REGION, AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY
